    {
        Z = C + VEC4(Z.x * (2*Z.w + Z.y + Z.z),
                     Z.y * (2*Z.w + Z.z + Z.x),
                     Z.z * (2*Z.w + Z.x + Z.y),
                     Zsc.w - Zsc.x - Zsc.y - Zsc.z);

        Zsc = Z * Z;

        FLOAT_T sum_sc = 0.0;
