//mbx_2025, an nD Mandelbrot fractal extension,
//part of 4DCraft, designed in 2025

const int
    // C
    R=POS0,  S=POS1,  T=POS2,  U=POS3,
    // Z
    r=TMP0+1,  s=TMP0+2,  t=TMP0+3,  u=TMP0+4,
    // 4th component of Z times 2
    _2u=TMP0+5,
    // squared value of each component of Z
    r2=TMP0+6,  s2=TMP0+7,  t2=TMP0+8,  u2=TMP0+9,
    // Z² (= Z∘Z); temporary values
    _r=TMP0+10,  _s=TMP0+11,  _t=TMP0+12,  _u=TMP0+13;

const int N_TMP_BUFFERS = _u + 1 - TMP0;

#define ESCAPE 2
#define ESCAPE2 (ESCAPE*ESCAPE)


/*
// formula using vec4's:
int compute ()
{
    VEC4 C;
    for (int axis=0; axis<4; axis++)
        C[axis] = to_float(POS0 + axis);

    VEC4 Z = VEC4(0,0,0,0);  // zero perturbation
